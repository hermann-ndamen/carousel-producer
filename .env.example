# Copy to .env and fill in. Never commit your real .env.

# Anthropic — used for research, outline drafting, and captions.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional model override (defaults to claude-opus-4-8).
CAROUSEL_MODEL=claude-opus-4-8

# Google Gemini — used by the Nano Banana image provider.
GEMINI_API_KEY=your-gemini-api-key-here
# Optional image model override.
NANO_BANANA_MODEL=gemini-2.5-flash-image

# Web image-search provider (optional). Any JSON image-search API works:
# set the endpoint and the auth value sent in the Authorization header.
IMAGE_SEARCH_ENDPOINT=https://your-image-search-api.example.com/search
IMAGE_SEARCH_API_KEY=your-image-search-key-here
